{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/token/(.*)",
      "destination": "https://paytm-token.onrender.com/api/token/$1"
    },
    {
      "source": "/api/token",
      "destination": "https://paytm-token.onrender.com/api/token"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
